# Cloudinary — unsigned upload (Upload preset: Signing mode = Unsigned)
# https://cloudinary.com/documentation/upload_presets
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# EmailJS — https://www.emailjs.com/docs/
# Template cần biến khớp code (ví dụ {{name}}, {{email}})
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
# Tùy chọn: template riêng cho email thông báo duyệt trường.
# Nếu bỏ trống sẽ fallback sang VITE_EMAILJS_TEMPLATE_ID.
VITE_EMAILJS_SCHOOL_VERIFIED_TEMPLATE_ID=
# Template EmailJS: campus phụ gửi yêu cầu thêm nguồn lực tới trụ sở (mặc định template_ddj9q5l nếu bỏ trống).
# Có thể dùng riêng service/public key cho flow quota; nếu bỏ trống sẽ fallback sang biến welcome.
VITE_EMAILJS_QUOTA_REQUEST_TEMPLATE_ID=
VITE_EMAILJS_QUOTA_REQUEST_SERVICE_ID=
VITE_EMAILJS_QUOTA_REQUEST_PUBLIC_KEY=
VITE_EMAILJS_PUBLIC_KEY=

# MapTiler API key (frontend build-time env)
VITE_MAPTILER_API_KEY=
